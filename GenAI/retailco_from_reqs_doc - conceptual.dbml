// ============================================================
// RetailCo Analytics Platform  |  Data Model
// Version 1.1  |  April 2025
// Domains: Customer, Order, Product
// Layers: Conceptual > Logical (3NF) > Physical (Snowflake Star Schema)
// DBML Specification: https://dbml.dbdiagram.io/home/
// ============================================================


// ============================================================
// LAYER 1 - CONCEPTUAL MODEL
// Entities and relationships only. No attributes beyond the
// DBML-required placeholder column. Entity and column names
// use Proper Case with spaces. Relationships use DBML Ref
// direction operators (< one-to-many, > many-to-one,
// - one-to-one). Self-referencing tables use two distinct
// column names to comply with DBML rule preventing error 5002.
// ============================================================

TableGroup "Layer 1 - Conceptual" {
  RetailCo."Customer"
  RetailCo."Customer Address"
  RetailCo."Customer Segment History"
  RetailCo."Order"
  RetailCo."Order Line Item"
  RetailCo."Promotion"
  RetailCo."Product"
  RetailCo."Category"
  RetailCo."Supplier"
}

Table RetailCo."Customer" [note: "A person or organisation registered with RetailCo. Unified identity across all channels."] {
  Id int [pk]
}

Table RetailCo."Customer Address" [note: "One or more physical addresses belonging to a customer. Typed as Billing, Shipping, or Both."] {
  Id int [pk]
}

Table RetailCo."Customer Segment History" [note: "Historical record of segment assignments for a customer, enabling cohort analysis at any past date."] {
  Id int [pk]
}

Table RetailCo."Order" [note: "A purchase transaction placed by a customer through one of the four commercial channels."] {
  Id int [pk]
}

Table RetailCo."Order Line Item" [note: "A single product entry within an order. The atomic grain of purchase activity."] {
  Id int [pk]
}

Table RetailCo."Promotion" [note: "A discount campaign optionally applied to an order. Types: Percentage, Fixed, BOGO."] {
  Id int [pk]
}

Table RetailCo."Product" [note: "A sellable item in the RetailCo catalogue, assigned to a leaf category and sourced from one primary supplier."] {
  Id int [pk]
}

Table RetailCo."Category" [note: "Hierarchical product classification with up to three levels: Root, Mid, Leaf."] {
  Id        int [pk]
  "Parent Id" int
}

Table RetailCo."Supplier" [note: "A vendor that supplies products to RetailCo."] {
  Id int [pk]
}

// Conceptual Relationships

Ref: RetailCo."Customer".Id < RetailCo."Customer Address".Id
Ref: RetailCo."Customer".Id < RetailCo."Customer Segment History".Id
Ref: RetailCo."Customer".Id < RetailCo."Order".Id
Ref: RetailCo."Order".Id < RetailCo."Order Line Item".Id
Ref: RetailCo."Promotion".Id < RetailCo."Order".Id
Ref: RetailCo."Product".Id < RetailCo."Order Line Item".Id
Ref: RetailCo."Category".Id < RetailCo."Product".Id
Ref: RetailCo."Category"."Parent Id" > RetailCo."Category".Id
Ref: RetailCo."Supplier".Id < RetailCo."Product".Id
