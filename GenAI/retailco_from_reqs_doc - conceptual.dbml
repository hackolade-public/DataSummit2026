// ============================================================
// RetailCo Analytics Platform  |  Data Model
// Version 1.1  |  April 2025
// Domains: Customer, Order, Product
// Layers: Conceptual > Logical (3NF) > Physical (Snowflake Star Schema)
// DBML Specification: https://dbml.dbdiagram.io/home/
// ============================================================


// ============================================================
// LAYER 1 - CONCEPTUAL MODEL
// Entities and relationships only. No attributes beyond the
// DBML-required placeholder column. Entity and column names
// use Proper Case with spaces. Relationships use DBML Ref
// direction operators (< one-to-many, > many-to-one,
// - one-to-one). Self-referencing tables use two distinct
// column names to comply with DBML rule preventing error 5002.
// ============================================================

TableGroup "Layer 1 - Conceptual" {
  RetailCo."C Customer"
  RetailCo."C Customer Address"
  RetailCo."C Customer Segment History"
  RetailCo."C Order"
  RetailCo."C Order Line Item"
  RetailCo."C Promotion"
  RetailCo."C Product"
  RetailCo."C Category"
  RetailCo."C Supplier"
}

Table RetailCo."C Customer" [note: "A person or organisation registered with RetailCo. Unified identity across all channels."] {
  Id int [pk]
}

Table RetailCo."C Customer Address" [note: "One or more physical addresses belonging to a customer. Typed as Billing, Shipping, or Both."] {
  Id int [pk]
}

Table RetailCo."C Customer Segment History" [note: "Historical record of segment assignments for a customer, enabling cohort analysis at any past date."] {
  Id int [pk]
}

Table RetailCo."C Order" [note: "A purchase transaction placed by a customer through one of the four commercial channels."] {
  Id int [pk]
}

Table RetailCo."C Order Line Item" [note: "A single product entry within an order. The atomic grain of purchase activity."] {
  Id int [pk]
}

Table RetailCo."C Promotion" [note: "A discount campaign optionally applied to an order. Types: Percentage, Fixed, BOGO."] {
  Id int [pk]
}

Table RetailCo."C Product" [note: "A sellable item in the RetailCo catalogue, assigned to a leaf category and sourced from one primary supplier."] {
  Id int [pk]
}

Table RetailCo."C Category" [note: "Hierarchical product classification with up to three levels: Root, Mid, Leaf."] {
  Id        int [pk]
  "Parent Id" int
}

Table RetailCo."C Supplier" [note: "A vendor that supplies products to RetailCo."] {
  Id int [pk]
}

// Conceptual Relationships

Ref: RetailCo."C Customer".Id < RetailCo."C Customer Address".Id
Ref: RetailCo."C Customer".Id < RetailCo."C Customer Segment History".Id
Ref: RetailCo."C Customer".Id < RetailCo."C Order".Id
Ref: RetailCo."C Order".Id < RetailCo."C Order Line Item".Id
Ref: RetailCo."C Promotion".Id < RetailCo."C Order".Id
Ref: RetailCo."C Product".Id < RetailCo."C Order Line Item".Id
Ref: RetailCo."C Category".Id < RetailCo."C Product".Id
Ref: RetailCo."C Category"."Parent Id" > RetailCo."C Category".Id
Ref: RetailCo."C Supplier".Id < RetailCo."C Product".Id
